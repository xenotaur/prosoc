#!/usr/bin/env bash
# Distill the Prosocial Navigation Charter
#
# This script is a thin wrapper around the Python distillation tool.
# All command-line arguments are forwarded verbatim.
#
# Examples:
#   scripts/distill/charter
#   scripts/distill/charter --dry-run
#   scripts/distill/charter --show-diffs
#   scripts/distill/charter --dry-run --show-diffs

set -euo pipefail

echo "Running Prosoc charter distillation..."
python -m prosoc.charter.distill "$@"
