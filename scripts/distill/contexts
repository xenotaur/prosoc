#!/usr/bin/env bash
# Distill social navigation context cards from Markdown to YAML
#
# This script compiles all context.md files under prosoc/contexts
# into context.yml files using the literate compiler pipeline.
#
# Supported layouts:
#   --layout directory   (default; one scenario per directory)
#   --layout flat        (legacy; one scenario per .md file)
#
# Common flags:
#   --dry-run     Do not write files; report what would change
#   --show-diffs  Show diffs between existing and generated YAML
#
# Examples:
#   scripts/distill_contexts
#   scripts/distill_contexts --dry-run --show-diffs
#   scripts/distill_contexts --layout flat

set -euo pipefail

echo "Distilling Prosoc social navigation context cards..."
set -x

python -m prosoc.contexts.distill "$@"

# Turn off tracing and print a blank line
{ set +x; } 2>/dev/null
echo

