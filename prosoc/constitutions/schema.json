{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Prosoc Constitution Card Schema",
  "type": "object",
  "required": [
    "constitution"
  ],
  "properties": {
    "constitution": {
      "type": "object",
      "required": [
        "id",
        "name",
        "schema_version",
        "rules"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "schema_version": {
          "type": "string"
        },
        "provenance": {
          "type": "object",
          "properties": {
            "derived_from": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "generation_method": {
              "type": "string",
              "enum": [
                "manual",
                "compiled",
                "auto-amended"
              ]
            },
            "generator": {
              "type": "string"
            },
            "date_generated": {
              "type": "string",
              "format": "date"
            }
          },
          "additionalProperties": false
        },
        "scope": {
          "type": "object",
          "properties": {
            "domain": {
              "type": "string"
            },
            "contexts": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "exclusions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "id",
              "text",
              "type",
              "priority"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "text": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": [
                  "must",
                  "must_not",
                  "should"
                ]
              },
              "priority": {
                "type": "string",
                "enum": [
                  "high",
                  "medium",
                  "low"
                ]
              },
              "rationale": {
                "type": "string"
              },
              "examples": {
                "type": "object",
                "properties": {
                  "positive": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "negative": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "additionalProperties": false
              },
              "evaluation_tags": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          }
        },
        "conflict_resolution": {
          "type": "object",
          "properties": {
            "strategy": {
              "type": "string"
            },
            "notes": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "runtime_profile": {
          "type": "object",
          "properties": {
            "estimated_tokens": {
              "type": "integer"
            },
            "recommended_subset": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "evaluation": {
          "type": "object",
          "properties": {
            "benchmarks": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "known_failure_modes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "regression_tests": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "test_id",
                  "description"
                ],
                "properties": {
                  "test_id": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}